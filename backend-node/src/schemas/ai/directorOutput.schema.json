{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DirectorOutput",
  "type": "object",
  "required": ["nextEvent", "weather", "pacing", "adjustments", "objective"],
  "properties": {
    "nextEvent": {
      "type": "object",
      "required": ["spawnEvent", "location"],
      "properties": {
        "spawnEvent": { "type": "string" },
        "location": { "type": "string" }
      },
      "additionalProperties": false
    },
    "weather": { "type": "string" },
    "pacing": {
      "type": "object",
      "required": ["intensity", "delaySeconds"],
      "properties": {
        "intensity": { "type": "number", "minimum": 0, "maximum": 1 },
        "delaySeconds": { "type": "integer", "minimum": 10, "maximum": 600 }
      },
      "additionalProperties": false
    },
    "adjustments": {
      "type": "object",
      "required": ["dangerDelta", "corruptionDelta"],
      "properties": {
        "dangerDelta": { "type": "integer", "minimum": -3, "maximum": 3 },
        "corruptionDelta": { "type": "integer", "minimum": -10, "maximum": 10 }
      },
      "additionalProperties": false
    },
    "objective": {
      "type": "object",
      "required": ["type", "target", "description"],
      "properties": {
        "type": { "type": "string" },
        "target": { "type": "string" },
        "description": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
