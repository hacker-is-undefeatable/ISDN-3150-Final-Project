{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RewardOutput",
  "type": "object",
  "required": ["cardId", "rarity", "unlock"],
  "properties": {
    "cardId": { "type": "string" },
    "rarity": { "type": "string", "enum": ["common", "uncommon", "rare", "legendary"] },
    "unlock": {
      "type": "object",
      "required": ["type", "value"],
      "properties": {
        "type": { "type": "string", "enum": ["card", "character", "set"] },
        "value": { "type": "string" }
      },
      "additionalProperties": false
    },
    "reason": { "type": "string" }
  },
  "additionalProperties": false
}
